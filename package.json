{
  "name": "@mgvdev/nestjs-ai",
  "version": "0.2.0",
  "description": "Structured AI toolkit for NestJS — agents, tools, structured output, streaming and embeddings on top of the Vercel AI SDK.",
  "author": "Maxence Guyonvarho",
  "license": "MIT",
  "keywords": [
    "nestjs",
    "ai",
    "llm",
    "agents",
    "tools",
    "openai",
    "anthropic",
    "vercel-ai-sdk",
    "embeddings"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./typeorm": {
      "types": "./dist/typeorm.d.ts",
      "import": "./dist/typeorm.js",
      "require": "./dist/typeorm.cjs"
    },
    "./websocket": {
      "types": "./dist/websocket.d.ts",
      "import": "./dist/websocket.js",
      "require": "./dist/websocket.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    }
  },
  "files": [
    "dist",
    "documentation",
    "skill",
    "README.md",
    "LICENSE"
  ],
  "nestBoost": {
    "skills": [
      "skill"
    ]
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/event-emitter": "^2.0.0 || ^3.0.0",
    "@nestjs/typeorm": "^10.0.0 || ^11.0.0",
    "ai": "^7.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0",
    "typeorm": "^0.3.0 || ^1.0.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@nestjs/event-emitter": {
      "optional": true
    },
    "@nestjs/typeorm": {
      "optional": true
    },
    "typeorm": {
      "optional": true
    },
    "bullmq": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "@nestjs/websockets": {
      "optional": true
    },
    "@nestjs/platform-socket.io": {
      "optional": true
    },
    "socket.io": {
      "optional": true
    },
    "@qdrant/js-client-rest": {
      "optional": true
    },
    "@pinecone-database/pinecone": {
      "optional": true
    },
    "msw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.95",
    "@ai-sdk/google": "^3.0.90",
    "@ai-sdk/openai": "^3.0.82",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/testing": "^11.0.0",
    "@nestjs/typeorm": "^11.0.3",
    "@nestjs/websockets": "^11.1.28",
    "@swc/core": "^1.15.43",
    "@types/node": "^22.0.0",
    "ai": "^7.0.17",
    "better-sqlite3": "^12.11.1",
    "msw": "^2.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "tsup": "^8.3.0",
    "typeorm": "^1.0.0",
    "typescript": "^5.6.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=22"
  }
}
